{
  "expo": {
    "name": "Scheduly",
    "slug": "scheduly",
    "version": "1.0.0",
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": ["expo-font", "expo-secure-store"],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#BFE6FB"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    }
  }
}
